{
  "manifest_version": 3,
  "name": "PubMed IA Scholar Helper",
  "version": "1.1.0",
  "description": "Add a minimal Internet Archive Scholar sidebar card to PubMed article pages.",
  "content_scripts": [
    {
      "matches": [
        "https://pubmed.ncbi.nlm.nih.gov/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
